%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#dbeafe",
    "primaryTextColor": "#1e3a5f",
    "primaryBorderColor": "#3b82f6",
    "lineColor": "#475569",
    "secondaryColor": "#fef9c3",
    "tertiaryColor": "#dcfce7",
    "fontSize": "13px"
  },
  "flowchart": {"curve": "basis", "padding": 12}
