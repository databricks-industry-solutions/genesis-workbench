  WF4 --> EP2
  WF5 --> EP3
  WF6 --> EP4
  WF7 --> EP5
  WF7 --> EP6

  classDef submod fill:#fce7f3,stroke:#9d174d,color:#831843,font-weight:bold,rx:6
  classDef wflow  fill:#fbcfe8,stroke:#9d174d,color:#831843,rx:6
  classDef wbatch fill:#fdf2f8,stroke:#9d174d,color:#831843,stroke-dasharray:4 3,rx:6
  classDef endpt  fill:#fff0f7,stroke:#9d174d,color:#831843,rx:6

  class SM1,SM2,SM3,SM4,SM5,SM6,SM7,SM8 submod
  class WF1,WF4,WF5,WF6,WF7,WF8,WF9 wflow
  class WF2,WF3,WF10 wbatch
  class EP1,EP2,EP3,EP4,EP5,EP6 endpt
