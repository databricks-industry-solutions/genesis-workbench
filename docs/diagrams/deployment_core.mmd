%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#dbeafe",
    "primaryTextColor": "#1e3a5f",
    "primaryBorderColor": "#1e40af",
    "lineColor": "#3b82f6",
    "edgeLabelBackground": "#ffffff",
    "fontFamily": "ui-sans-serif, system-ui, sans-serif",
    "fontSize": "14px"
  }
}}%%
flowchart LR

  subgraph COL1["  Sub-modules / Models  "]
    direction TB
    SM_CORE("Core Infrastructure")
    SM_APP("Genesis Workbench App")
    SM_MCP("MCP Server App")
    SM_UC("Unity Catalog")
  end

  subgraph COL2["  Workflows  "]
    direction TB
    WF1("initialize_core")
    WF2("deploy_model")
    WF3("start_all_endpoints")
    WF4("grant_app_permissions")
  end

  subgraph COL3["  App & Catalog Resources  "]
    direction TB
    APP["Genesis Workbench App\n(React UI + FastAPI · Vortex)"]
    MCP["MCP Server App\n(FastMCP · streamable HTTP /mcp)"]
    UC["Unity Catalog Schema\n+ Tables + Volumes"]
  end

  subgraph COL4["  Common Service Layer  "]
    direction TB
    CORE["Capability Core\ncapabilities + executor\n(genesis_workbench wheel)"]
    EP(["Model Serving\nEndpoints"])
    JOBS(["Workflow Jobs\n(orchestrator + batch)"])
  end

  SM_CORE --> WF1
  SM_CORE --> WF2
  SM_CORE --> WF3
  SM_CORE --> WF4
  SM_APP  --> APP
  SM_MCP  --> MCP
  SM_UC   --> UC

  WF1 --> UC
  WF2 --> APP
  WF3 --> APP
  WF4 --> APP
  WF4 --> MCP

  %% Common service layer: both apps are thin adapters over one capability core,
  %% which invokes the deployed endpoints and dispatches the workflow jobs.
  APP  --> CORE
  MCP  --> CORE
  CORE --> EP
  CORE --> JOBS

  classDef submod  fill:#dbeafe,stroke:#1e40af,color:#1e3a5f,font-weight:bold,rx:6
  classDef wflow   fill:#bfdbfe,stroke:#1e40af,color:#1e3a5f,rx:6
  classDef res     fill:#eff6ff,stroke:#1e40af,color:#1e3a5f,font-weight:bold,rx:6
  classDef svc     fill:#dcfce7,stroke:#15803d,color:#14532d,font-weight:bold,rx:6
  classDef runtime fill:#ecfdf5,stroke:#15803d,color:#14532d,rx:6
  classDef colBox  fill:#f0f7ff,stroke:#93c5fd

  class SM_CORE,SM_APP,SM_MCP,SM_UC submod
  class WF1,WF2,WF3,WF4 wflow
  class APP,MCP,UC res
  class CORE svc
  class EP,JOBS runtime
